# Resend (emails de leads). Sin esto, POST /api/lead responde 503.
RESEND_API_KEY=
# Ejemplo: Summer87 <notificaciones@tudominio.com> (dominio verificado en Resend)
RESEND_FROM=

# CRM webhook (opcional). Si está definida, cada lead se envía también al CRM vía POST.
# Si no está definida o falla, el submit sigue funcionando normalmente.
CRM_WEBHOOK_URL=
